#!/usr/bin/env bash
# shellcheck source=/dev/null

set -Eeuo pipefail;

SELF_PATH="$(readlink -f "${BASH_SOURCE[0]}")";
BASE_DIR="${SELF_PATH%/*}";
SCRIPT_DIR="${BASE_DIR}/scripts";

source "${SCRIPT_DIR}/common.sh";
source "${SCRIPT_DIR}/state.sh";

source "${SCRIPT_DIR}/tui/core.sh";
source "${SCRIPT_DIR}/tui/menus.sh";
source "${SCRIPT_DIR}/tui/summary.sh";

source "${SCRIPT_DIR}/storage/partition.sh";
source "${SCRIPT_DIR}/storage/filesystem.sh";
source "${SCRIPT_DIR}/storage/mount.sh";

source "${SCRIPT_DIR}/install/basestrap.sh";
source "${SCRIPT_DIR}/install/bootloader.sh";
source "${SCRIPT_DIR}/install/handoff.sh";
source "${SCRIPT_DIR}/install/services.sh";
source "${SCRIPT_DIR}/install/users.sh";

source "${SCRIPT_DIR}/post/drivers.sh";
source "${SCRIPT_DIR}/post/networking.sh";
source "${SCRIPT_DIR}/post/desktop.sh";
source "${SCRIPT_DIR}/post/audio.sh";
source "${SCRIPT_DIR}/post/extras.sh";

source "${SCRIPT_DIR}/stages/preflight.sh";
source "${SCRIPT_DIR}/stages/storage.sh";
source "${SCRIPT_DIR}/stages/base.sh";
source "${SCRIPT_DIR}/stages/chroot.sh";
source "${SCRIPT_DIR}/stages/post.sh";
source "${SCRIPT_DIR}/stages/finalize.sh";

MODE="";
DEBUG="false";
ARGV=();

parse_docblock() {
    local esc;
    local help="${1}";

    printf -v esc '\033';

    help="$(sed -E \
        's/^[[:space:]]*#\|[[:space:]]?//g' \
        <<< "${help}")";

    help="$(sed -E \
        "s/\{e:([0-9a-zA-Z;]+)\}/${esc}[\1/g" \
        <<< "${help}")";

    printf '%s\n' "${help}";
}

extract_docblock() {
    local function_name="${1}";
    local line;
    local docblock='';
    local -a buffer=();

    while IFS= read -r line || [[ -n "${line}" ]]; do
        if [[ "${line}" =~ ^[[:space:]]*#\| ]]; then
            buffer+=("${line}");
            continue;
        fi;

        if [[ "${line}" =~ ${function_name}\(\) ]]; then
            if [[ ${#buffer[@]} -gt 0 ]]; then
                printf -v docblock '%s\n' "${buffer[@]}";
                break;
            fi;
        fi;

        buffer=();
    done < "${SELF_PATH}";

    [[ -n "${docblock}" ]] \
        || die 'documentation not found';

    parse_docblock "${docblock}";
}

check_installer_version() {
    local local_version;
    local remote_version;

    [[ -f "${BASE_DIR}/VERSION" ]] \
        || return 0;

    local_version=$(
        tr -d '[:space:]' < "${BASE_DIR}/VERSION"
    );

    remote_version=$(
        curl -fsSL \
            'https://raw.githubusercontent.com/realvolk/ArtixTUI/main/VERSION' \
            2>/dev/null \
            | tr -d '[:space:]' \
            || true
    );

    [[ -n "${remote_version}" ]] \
        || return 0;

    if [[ "${local_version}" != "${remote_version}" ]]; then
        if ! tui_yesno \
            " Installer Outdated " \
"Installed version: ${local_version}
Latest version: ${remote_version}

This installer may contain bugs already fixed upstream.

It is strongly recommended to download
the latest version before continuing.

Continue anyway?"; then

            clear;
            printf '[*] Installation cancelled.\n';
            exit 0;
        fi
    fi
}

detect_partial_install() {
    mountpoint -q /mnt \
        || return 1;

    [[ -d /mnt/etc ]] \
        || return 1;

    [[ -d /mnt/var/lib/pacman ]] \
        || return 1;

    return 0;
}

run_install_pipeline() {
    stage_preflight;
    stage_storage;
    stage_base;
    stage_chroot;
    stage_post;
    stage_finalize;
}

start_auto_install() {
    tui_collect_install_config;

    tui_show_summary;

    if ! tui_yesno \
        " Begin Installation " \
        "Proceed with installation?"; then

        clear;
        printf '[*] Installation cancelled.\n';
        exit 0;
    fi;

    state_save;

    run_install_pipeline;
}

start_manual_install() {
    state_set INSTALL_MODE manual;

    run_install_pipeline;
}

resume_install() {
    state_load;

    run_install_pipeline;
}

start_recovery_install() {
    if ! detect_partial_install; then
        tui_msg \
            " Recovery Mode " \
            "No partial installation detected in /mnt."

        exit 1;
    fi

    if ! tui_yesno \
        " Recovery Mode " \
"Detected an existing installation mounted at /mnt.

This usually means a previous installation
was interrupted or partially completed.

Attempt recovery and continue installation?"; then

        clear;
        printf '[*] Recovery cancelled.\n';
        exit 0;
    fi

    printf '[*] Entering recovery mode...\n';

    run_install_pipeline;
}

#| {e:1;32m}Usage:{e:m} ./install [options]
#|
#| {e:1;33m}Options:{e:m}
#|   -a, --auto        TUI-driven automated Artix installation
#|   -m, --manual      Manual installation mode
#|   -r, --resume      Resume interrupted installation
#|   -rr, --recovery   Recover partially completed installation
#|   -d, --debug       Enable shell tracing
#|   -h, --help        Show this help message
main() {
    ensure_dirs;

    require_root;
    require_efi;
    check_installer_version;

    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -a|--auto)
                MODE='auto';
                shift;
                ;;

            -m|--manual)
                MODE='manual';
                shift;
                ;;

            -r|--resume)
                MODE='resume';
                shift;
                ;;

            -rr|--recovery)
                MODE='recovery';
                shift;
                ;;

            -d|--debug)
                DEBUG='true';
                shift;
                ;;

            -h|--help)
                extract_docblock main;
                exit 0;
                ;;

            *)
                ARGV+=("${1}");
                shift;
                ;;
        esac;
    done;

    if [[ "${DEBUG}" == 'true' ]]; then
        export ARTIX_DEBUG='true';

        exec 19> "${PWD}/artix-debug.log";

        export BASH_XTRACEFD=19;
        export PS4='+ ${BASH_SOURCE}:${LINENO}:${FUNCNAME[0]}: '

        set -x
    fi
    
    case "${MODE}" in
        auto)
            start_auto_install;
            ;;

        manual)
            start_manual_install;
            ;;

        resume)
            resume_install;
            ;;

        recovery)
            start_recovery_install;
            ;;

        *)
            extract_docblock main;
            exit 1;
            ;;
    esac;
}

main "$@";