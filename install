#!/usr/bin/env bash
# shellcheck source=/dev/null

set -Eeuo pipefail;

SELF_PATH="$(readlink -f "${BASH_SOURCE[0]}")";
BASE_DIR="${SELF_PATH%/*}";
SCRIPT_DIR="${BASE_DIR}/scripts";

installer_abort() {
    clear;

    printf '\n[!] Installation interrupted.\n' >&2;
    printf '[!] The installation was NOT completed.\n' >&2;

    exit 130;
}

installer_error() {
    local rc="${1:-1}";
    local line="${2:-unknown}";

    clear;

    printf '\n[!] Installation failed at line: %s\n' \
        "${line}" \
        >&2;

    printf '[!] Exit status: %s\n' \
        "${rc}" \
        >&2;

    printf '[!] The installation was NOT completed.\n' >&2;

    exit "${rc}";
}

self_update_installer() {
    local -a restart_args=("$@");
    local repo_url;
    local tmp_dir;

    repo_url='https://github.com/realvolk/ArtixTUI.git';

    tmp_dir="$(mktemp -d)";

    printf '[*] Downloading latest installer...\n';

    if ! git clone \
        --depth 1 \
        "${repo_url}" \
        "${tmp_dir}" \
        >/dev/null 2>&1; then

        printf '[!] Failed to download latest installer.\n';

        rm -rf "${tmp_dir}";

        return 1;
    fi

    if [[ ! -f "${tmp_dir}/install" ]]; then
        printf '[!] Invalid installer payload received.\n';

        rm -rf "${tmp_dir}";

        return 1;
    fi

    printf '[*] Replacing old installer files...\n';

    find "${BASE_DIR}" \
        -mindepth 1 \
        -maxdepth 1 \
        ! -name '.git' \
        -exec rm -rf {} +;

    cp -a \
        "${tmp_dir}/." \
        "${BASE_DIR}/";

    chmod +x "${BASE_DIR}/install";

    rm -rf "${tmp_dir}";

    printf '[*] Restarting updated installer...\n';

    exec "${BASE_DIR}/install" "${restart_args[@]}";
}

check_installer_version() {
    local local_version;
    local remote_version;

    [[ -f "${BASE_DIR}/VERSION" ]] \
        || return 0;

    local_version="$(
        tr -d '[:space:]' < "${BASE_DIR}/VERSION"
    )";

    remote_version="$(
        curl -fsSL \
            'https://raw.githubusercontent.com/realvolk/ArtixTUI/main/VERSION' \
            2>/dev/null \
            | tr -d '[:space:]' \
            || true
    )";

    [[ -n "${remote_version}" ]] \
        || return 0;

    if [[ "${local_version}" == "${remote_version}" ]]; then
        return 0;
    fi

    if [[ "$(
        printf '%s\n%s\n' \
            "${local_version}" \
            "${remote_version}" \
            | sort -V \
            | tail -n1
    )" != "${remote_version}" ]]; then
        return 0;
    fi

    if tui_yesno \
        " Installer Outdated " \
"Installed version: ${local_version}
Latest version: ${remote_version}

A newer installer version is available.

Would you like to update now?"; then

        if self_update_installer "$@"; then
            exit 0;
        fi

        if ! tui_yesno \
            " Update Failed " \
"The automatic update failed.

Continue using the current installer anyway?"; then

            clear;
            printf '[*] Installation cancelled.\n';
            exit 0;
        fi

    else
        if ! tui_yesno \
            " Continue Anyway " \
"This installer may contain bugs already fixed upstream.

Continue using the outdated version?"; then

            clear;
            printf '[*] Installation cancelled.\n';
            exit 0;
        fi
    fi
}

verify_installer_layout() {
    local required_files=(
        common.sh
        state.sh
        recovery.sh
        kernels.sh
    );

    local required_dirs=(
        tui
        storage
        install
        post
        stages
    );

    local file;
    local dir;

    for file in "${required_files[@]}"; do
        [[ -f "${SCRIPT_DIR}/${file}" ]] \
            || return 1;
    done

    for dir in "${required_dirs[@]}"; do
        [[ -d "${SCRIPT_DIR}/${dir}" ]] \
            || return 1;
    done

    return 0;
}

source_tree() {
    local dir;
    local file;

    for dir in "$@"; do
        [[ -d "${SCRIPT_DIR}/${dir}" ]] \
            || die "missing script directory: ${dir}";

        while IFS= read -r -d '' file; do
            # shellcheck source=/dev/null
            source "${file}";
        done < <(
            find "${SCRIPT_DIR}/${dir}" \
                -maxdepth 1 \
                -type f \
                -name '*.sh' \
                -print0 \
                | sort -z
        )
    done
}

trap 'installer_abort' INT TERM;
trap 'installer_error $? ${LINENO}' ERR;

if ! verify_installer_layout; then
    printf '[*] Installer layout is incomplete.\n';
    printf '[*] Attempting automatic repair...\n';

    if ! self_update_installer; then
        die 'failed to repair installer layout';
    fi

    exit 0;
fi

source "${SCRIPT_DIR}/common.sh";
source "${SCRIPT_DIR}/state.sh";
source "${SCRIPT_DIR}/recovery.sh";
source "${SCRIPT_DIR}/kernels.sh";

source_tree \
    tui \
    storage \
    install \
    post \
    stages

MODE="";
DEBUG="false";
ARGV=();

parse_docblock() {
    local esc;
    local help="${1}";

    printf -v esc '\033';

    help="$(sed -E \
        's/^[[:space:]]*#\|[[:space:]]?//g' \
        <<< "${help}")";

    help="$(sed -E \
        "s/\{e:([0-9a-zA-Z;]+)\}/${esc}[\1/g" \
        <<< "${help}")";

    printf '%s\n' "${help}";
}

extract_docblock() {
    local function_name="${1}";
    local line;
    local docblock='';
    local -a buffer=();

    while IFS= read -r line || [[ -n "${line}" ]]; do
        if [[ "${line}" =~ ^[[:space:]]*#\| ]]; then
            buffer+=("${line}");
            continue;
        fi;

        if [[ "${line}" =~ ${function_name}\(\) ]]; then
            if [[ ${#buffer[@]} -gt 0 ]]; then
                printf -v docblock '%s\n' "${buffer[@]}";
                break;
            fi;
        fi;

        buffer=();
    done < "${SELF_PATH}";

    [[ -n "${docblock}" ]] \
        || die 'documentation not found';

    parse_docblock "${docblock}";
}

run_install_pipeline() {
    stage_preflight \
        || die 'preflight stage failed';

    stage_storage \
        || die 'storage stage failed';

    stage_base \
        || die 'base stage failed';

    stage_chroot \
        || die 'chroot stage failed';

    stage_post \
        || die 'post-install stage failed';

    stage_finalize \
        || die 'finalization stage failed';
}

start_auto_install() {
    tui_collect_install_config;

    tui_show_summary;

    if ! tui_yesno \
        " Begin Installation " \
        "Proceed with installation?"; then

        clear;
        printf '[*] Installation cancelled.\n';
        exit 0;
    fi;

    state_save;

    run_install_pipeline;
}

start_manual_install() {
    state_set INSTALL_MODE manual;

    run_install_pipeline;
}

resume_install() {
    if [[ ! -f "${STATE_FILE}" ]]; then
        die 'no saved installer state found';
    fi

    state_load;

    [[ -n "${DISK:-}" ]] \
        || die 'saved installer state is incomplete';

    run_install_pipeline;
}

start_recovery_install() {
    local recovery_status;

    if ! recovery_detect_install; then
        tui_msg \
            " Recovery Mode " \
            "No partial installation detected in /mnt."

        exit 1;
    fi

    recovery_import_state;

    recovery_status="$(
        recovery_get_status
    )";

    if ! tui_yesno \
        " Recovery Mode " \
"Detected an existing installation mounted at /mnt.

${recovery_status}

This usually means a previous installation
was interrupted or partially completed.

Attempt recovery and continue installation?"; then

        clear;
        printf '[*] Recovery cancelled.\n';
        exit 0;
    fi

    printf '[*] Entering recovery mode...\n';

    run_install_pipeline;
}

#| {e:1;32m}Usage:{e:m} ./install [options]
#|
#| {e:1;33m}Options:{e:m}
#|   -a, --auto        TUI-driven automated Artix installation
#|   -m, --manual      Manual installation mode
#|   -r, --resume      Resume interrupted installation
#|   -rr, --recovery   Recover partially completed installation
#|   -d, --debug       Enable shell tracing
#|   -h, --help        Show this help message
main() {
    ensure_dirs;

    require_root;
    require_efi;

    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -a|--auto)
                [[ -n "${MODE}" ]] \
                    && die 'conflicting installation mode flags';

                MODE='auto';
                shift;
                ;;

            -m|--manual)
                [[ -n "${MODE}" ]] \
                    && die 'conflicting installation mode flags';

                MODE='manual';
                shift;
                ;;

            -r|--resume)
                [[ -n "${MODE}" ]] \
                    && die 'conflicting installation mode flags';

                MODE='resume';
                shift;
                ;;

            -rr|--recovery)
                [[ -n "${MODE}" ]] \
                    && die 'conflicting installation mode flags';

                MODE='recovery';
                shift;
                ;;

            -d|--debug)
                DEBUG='true';
                shift;
                ;;

            -h|--help)
                extract_docblock main;
                exit 0;
                ;;

            *)
                ARGV+=("${1}");
                shift;
                ;;
        esac;
    done;

    if [[ "${DEBUG}" == 'true' ]]; then
        export ARTIX_DEBUG='true';

        exec 19> "${PWD}/artix-debug.log";

        export BASH_XTRACEFD=19;
        export PS4='+ ${BASH_SOURCE}:${LINENO}:${FUNCNAME[0]}: '

        set -x
    fi

    check_installer_version "${ARGV[@]}";

    case "${MODE}" in
        auto)
            start_auto_install;
            ;;

        manual)
            start_manual_install;
            ;;

        resume)
            resume_install;
            ;;

        recovery)
            start_recovery_install;
            ;;

        *)
            extract_docblock main;
            exit 1;
            ;;
    esac;
}

main "$@";